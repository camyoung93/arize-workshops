# Media Agent Demo — environment variables
# Copy to .env and fill in your values

# ── Arize AX ──────────────────────────────────────────────────────────────────
ARIZE_SPACE_ID=your-arize-space-id
ARIZE_API_KEY=your-arize-api-key
ARIZE_PROJECT_NAME=media-agent-demo

# ── Google Cloud / Vertex AI ─────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_REGION=us-central1
GEMINI_MODEL=gemini-2.0-flash

# Use Vertex AI for the ADK agent (and tools). Without this, the agent expects GOOGLE_API_KEY (Gemini API).
GOOGLE_GENAI_USE_VERTEXAI=true

# ── ADK session (Runner / session creation) ───────────────────────────────────
ADK_APP_NAME=media-agent-demo
ADK_USER_ID=demo-user

# ── Database ───────────────────────────────────────────────────────────────────
# Path to SQLite DB. Default: data/media.db relative to the demo directory.
# MEDIA_DB_PATH=

# Auth: run `gcloud auth application-default login`
# Or set GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
